{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Grimoire",
  "version": "0.1.0",
  "identifier": "com.hexpc.grimoire",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Grimoire",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "backgroundColor": "#111111"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkK",
      "endpoints": [
        "https://github.com/HexGP/Grimoire/releases/latest/download/latest.json"
      ]
    }
  }
}
